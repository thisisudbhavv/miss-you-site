{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/thoughts.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/*.jpeg",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/thoughts",
      "dest": "/backend/api/thoughts.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/backend/api/$1"
    },
    {
      "src": "/(.*\\.(jpeg|jpg|png|gif|css|js|ico|svg))",
      "dest": "/frontend/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
